@using System.Globalization
@inject IClient Api
@inject IErrorHandlerService ErrorHandler

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="AlarmTitle" Label="Title" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="Time" Label="Time" Variant="Variant.Outlined"
                          HelperText="Format: yyyy-MM-dd HH:mm" Required="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public Alarm Item { get; set; } = null!;

    private string AlarmTitle { get; set; } = string.Empty;
    private string Time { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        AlarmTitle = Item.Title;
        Time = (Item.Time ?? DateTimeOffset.Now).ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);
    }

    private void Cancel() => MudDialog.Cancel();

    private Task SaveAsync() => ErrorHandler.RunSafeAsync(async () =>
    {
        var parsedTime = DateTimeOffset.Parse(Time, CultureInfo.InvariantCulture);
        var trimmedTitle = AlarmTitle.Trim();

        if (Item.Id == 0)
        {
            await Api.AlarmsCreateAsync(new Alarm { Title = trimmedTitle, Time = parsedTime });
        }
        else
        {
            await Api.AlarmsUpdateAsync(new Alarm
            {
                Id = Item.Id,
                Title = trimmedTitle,
                Time = parsedTime
            });
        }

        MudDialog.Close(DialogResult.Ok(true));
    });
}
