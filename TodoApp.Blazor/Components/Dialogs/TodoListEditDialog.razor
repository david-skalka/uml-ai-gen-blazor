@using TodoApp.Api
@inject IClient Api
@inject IErrorHandlerService ErrorHandler

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Name" Label="Name" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public TodoList Item { get; set; } = default!;

    private string Name { get; set; } = string.Empty;
    private string Description { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        Name = Item.Name;
        Description = Item.Description ?? string.Empty;
    }

    private void Cancel() => MudDialog.Cancel();

    private Task SaveAsync() => ErrorHandler.RunSafeAsync(async () =>
    {
        var trimmedName = Name.Trim();
        var trimmedDescription = Description.Trim();

        if (Item.Id == 0)
        {
            await Api.TodoListsCreateAsync(new TodoList
            {
                Name = trimmedName,
                Description = trimmedDescription
            });
        }
        else
        {
            await Api.TodoListsUpdateAsync(new TodoList
            {
                Id = Item.Id,
                Name = trimmedName,
                Description = trimmedDescription
            });
        }

        MudDialog.Close(DialogResult.Ok(true));
    });
}
