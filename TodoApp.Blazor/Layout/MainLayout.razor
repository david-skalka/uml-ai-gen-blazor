@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudText Typo="Typo.h6">Todo App</MudText>
        <MudSpacer />
        <MudButton Href="/todo-list" Color="Color.Inherit" Variant="Variant.Text">Todo List</MudButton>
        <MudButton Href="/alarms" Color="Color.Inherit" Variant="Variant.Text">Alarm</MudButton>
    </MudAppBar>

    <MudMainContent Class="pa-4 mud-main-content-below-appbar">
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new();
}
